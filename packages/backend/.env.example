# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=ai_platform

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# 企业 SSO 配置
SSO_CLIENT_ID=your_sso_client_id
SSO_CLIENT_SECRET=your_sso_client_secret
SSO_TOKEN_URL=https://your-sso-server.com/oauth/token
SSO_USERINFO_URL=https://your-sso-server.com/oauth/userinfo
SSO_CALLBACK_URL=http://localhost:3000/api/auth/callback

# 服务端口
PORT=3000
